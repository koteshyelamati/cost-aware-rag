# MongoDB connection string — use Atlas URI in production
MONGODB_URI=mongodb://mongo:27017

# Database and collection names
DB_NAME=rag_db
COLLECTION_NAME=documents
COSTS_COLLECTION=query_costs

# Gemini API key from aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# Model routing
SIMPLE_MODEL=gemini-1.5-flash
COMPLEX_MODEL=gemini-1.5-pro
COMPLEXITY_THRESHOLD=0.4

# Redis semantic cache
REDIS_URL=redis://redis:6379
CACHE_TTL=3600
CACHE_SIMILARITY_THRESHOLD=0.92

# API authentication key for X-API-Key header
API_KEY=change-this-in-production

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
